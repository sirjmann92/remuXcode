# Node and Python cache
frontend/node_modules
frontend/build
frontend/.svelte-kit
__pycache__/
*.pyc
*.pyo
backend/__pycache__/
backend/utils/__pycache__/
backend/workers/__pycache__/

# Python virtualenv (never used by the image; only bloats build context)
.venv/
venv/

# Logs
logs/
*.log

# Database
*.db

# Runtime config volume (secrets/state; Dockerfile never COPYs this, but
# exclude explicitly so a future COPY change can't accidentally bake it in)
config/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp

# Docker
Dockerfile*
.dockerignore

# Environment
.env

# Misc
*.bak
*.tmp
.git
.gitignore

# CI/CD and linting config (not needed in image)
.github/
.pre-commit-config.yaml
biome.json
pyproject.toml
pyrightconfig.json
requirements-lint.txt

# Legacy files
legacy/
tests/

# Documentation
README.md
QUICKSTART.md
ROADMAP.md
LICENSE
