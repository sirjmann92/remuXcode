# remuXcode Environment
# Copy to .env and fill in your values.
# All other processing settings live in config/config.yaml (auto-created on first run).

# Sonarr
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

# API key for webhook authentication
# Auto-generated on first run and stored in config/.api_key if left blank.
# To set a custom key: openssl rand -hex 32
REMUXCODE_API_KEY=
